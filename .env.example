# ============================================================
# NEVER commit .env — only commit this .env.example file
# Copy this file to .env and fill in your real values
# ============================================================

# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
# Dev guild for instant slash command updates (leave blank for global rollout)
DISCORD_GUILD_ID=your_dev_guild_id_here

# Comma-separated Discord role IDs that grant full sudo/admin access
SUDO_ROLE_IDS=111111111111111111,222222222222222222

# Legacy fallback sudo role — use SUDO_ROLE_IDS instead
# DISCORD_PORTAL_ADMIN_ROLE_ID=your_portal_admin_role_id_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/otterbot
# Only used by docker-compose if you want a non-default password
POSTGRES_PASSWORD=your_db_password_here

# McKenzie / Euphoric API
EUPHORIC_API_BASE_URL=https://mke.api.euphoric.gg
EUPHORIC_API_KEY=your_euphoric_api_key_here

# Uptime Kuma push monitor URL (optional)
# UPTIME_KUMA_PUSH_URL=https://your-kuma-host/api/push/xxxxxxxxxx?status=up&msg=OK&ping=

# ── Bot owner — receives /report DMs and startup pings ─────────────────────────
BOT_OWNER_ID=

# ── /report — files GitHub issues from inside Discord ─────────────────────────
# GITHUB_TOKEN: fine-grained PAT scoped to "Issues: Read & Write" on GITHUB_REPO.
# GITHUB_REPO:  "owner/name", e.g. jason-tucker/otterbot
# Both optional — /report replies with a friendly "not configured" error if missing.
# The bot owner (BOT_OWNER_ID above) reviews and approves each report via DM
# before the issue is filed.
GITHUB_TOKEN=
GITHUB_REPO=

# Environment
NODE_ENV=development
