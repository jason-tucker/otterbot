#!/usr/bin/env bash
# otterbot — management CLI for the Docker-based Otterbot deployment
#
# Install once on a server:
#   sudo cp scripts/otterbot /usr/local/bin/otterbot
#   sudo chmod +x /usr/local/bin/otterbot

set -Eeuo pipefail

SERVICE="otterbot"

detect_project_dir() {
    if [ -n "${PROJECT_DIR:-}" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
        echo "$PROJECT_DIR"; return
    fi
    for candidate in \
        "$HOME/projects/otterbot" \
        "/home/botuser/projects/otterbot" \
        "/root/projects/otterbot" \
        "$(pwd)"; do
        if [ -f "$candidate/docker-compose.yml" ]; then
            echo "$candidate"; return
        fi
    done
    echo "ERROR: otterbot project directory not found." >&2
    echo "Set PROJECT_DIR=/path/to/otterbot or run from inside the repo." >&2
    exit 1
}

PROJECT_DIR=$(detect_project_dir)
cd "$PROJECT_DIR"

cmd="${1:-status}"
shift || true

case "$cmd" in
    start)    docker compose up -d "$@"; docker compose ps ;;
    stop)     docker compose stop; echo "✓ otterbot stack stopped." ;;
    down)     docker compose down "$@"; echo "✓ otterbot stack removed." ;;
    restart)  docker compose restart "$SERVICE"; docker compose ps "$SERVICE" ;;
    status|ps) docker compose ps ;;
    logs)     docker compose logs "$SERVICE" -f --tail=50 "$@" ;;
    tail)     N="${1:-30}"; docker compose logs "$SERVICE" --tail="$N" ;;
    pull)     docker compose pull "$@" ;;
    update)
        echo "▶ Pulling latest source..."
        git fetch --all
        git reset --hard origin/main
        echo "▶ Pulling latest image..."
        docker compose pull "$SERVICE"
        echo "▶ Restarting..."
        docker compose up -d --remove-orphans
        echo "✓ otterbot updated."
        docker compose ps
        ;;
    build)    docker compose build "$@" ;;
    rebuild)  docker compose up -d --build --remove-orphans ;;
    deploy)
        docker compose run --rm "$SERVICE" node dist/bot/registerCommands.js
        ;;
    shell|exec) docker compose exec "$SERVICE" sh ;;
    db:shell|psql)
        docker compose exec db psql -U otterbot otterbot
        ;;
    env)
        ${EDITOR:-nano} .env
        echo "▶ Reloading containers..."
        docker compose up -d
        ;;
    where)    echo "$PROJECT_DIR" ;;
    *)
        cat <<EOF
Usage: otterbot <command>

  start         start the stack
  stop          stop the stack (preserves volumes)
  restart       restart just the bot container
  down          stop and remove containers (preserves volumes)
  status / ps   show container status
  logs          tail live logs
  tail [N]      show last N lines (default 30)
  pull          pull latest image from registry
  update        git pull + docker compose pull + up -d
  build         build image locally
  rebuild       up -d with --build
  deploy        register slash commands
  shell / exec  open shell inside the bot container
  db:shell      open psql against postgres
  env           edit .env and restart to apply
  where         print the auto-detected project directory

Project dir: $PROJECT_DIR
EOF
        ;;
esac
